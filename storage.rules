rules_version = '2';
// Deploy: Firebase Console → Storage → Rules, or: firebase deploy --only storage
// (ensure firebase.json includes "storage": { "rules": "storage.rules" })

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
